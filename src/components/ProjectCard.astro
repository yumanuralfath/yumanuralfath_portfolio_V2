---
// src/components/ProjectCard.astro
import type { Project } from "../data/projects";
import { ExternalLink, Code, Layout, Database, Download, Maximize2, X, Monitor, Smartphone, Terminal } from "lucide-astro";
import { getLangFromUrl } from "@/i18n/utils";
import { Image } from "astro:assets";

interface Props {
  project: Project;
  compact?: boolean;
  loading?: "eager" | "lazy";
}

const { project, compact = false, loading = "eager" } = Astro.props;
const { slug, title, description, detail, tags, href, repo, frontend_repo, backend_repo, download_url, downloads, year, image, thumbnail, video } = project;

const lang = getLangFromUrl(Astro.url);
const displayDesc = compact ? description[lang] : (detail?.[lang] ?? description[lang]);

const mediaSource = video || image;
const isVideo = mediaSource?.endsWith('.mp4') || mediaSource?.endsWith('.webm') || mediaSource?.endsWith('.mkv') || mediaSource?.endsWith('.mov');
const thumbSource = thumbnail || (isVideo ? null : image);

const getPlatformIcon = (platform: string) => {
  switch (platform) {
    case 'windows': return Monitor;
    case 'android': return Smartphone;
    case 'linux': return Terminal;
    default: return Download;
  }
};
---

<article class="relative group p-6 border border-brand-border rounded-lg glass overflow-hidden transition-all duration-300 hover:border-brand-accent hover:-translate-y-1">
  <!-- Glowing Laboratory Effect -->
  <div class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-brand-accent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

  {(thumbSource || isVideo) && (
    <>
      <div 
        class="relative w-full aspect-video mb-5 rounded-md overflow-hidden border border-brand-border/50 bg-brand-bg group-hover:border-brand-accent/30 transition-colors cursor-zoom-in project-media-container"
        data-slug={slug}
      >
        <!-- Thumbnail -->
        {thumbSource && (
          <Image 
            src={thumbSource} 
            alt={title} 
            width={800} 
            height={450} 
            loading={loading}
            class:list={[
              "absolute inset-0 w-full h-full object-cover transition-opacity duration-500 z-10",
              isVideo ? "opacity-80 group-hover:opacity-0" : "opacity-80 group-hover:opacity-100"
            ]}
          />
        )}

        <!-- Video Preview -->
        {isVideo && (
          <video 
            src={mediaSource} 
            muted 
            loop 
            playsinline 
            class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500 video-preview"
          ></video>
        )}

        <!-- Fallback Image (if no thumbnail and not video) -->
        {!thumbSource && !isVideo && image && (
          <Image 
            src={image} 
            alt={title} 
            width={800} 
            height={450} 
            loading={loading}
            class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-500" 
          />
        )}
        
        <!-- Analytical Overlay -->
        <div class="absolute inset-0 pointer-events-none opacity-20 group-hover:opacity-40 transition-opacity">
          <div class="absolute top-2 left-2 w-2 h-2 border-t border-l border-brand-accent"></div>
          <div class="absolute top-2 right-2 w-2 h-2 border-t border-r border-brand-accent"></div>
          <div class="absolute bottom-2 left-2 w-2 h-2 border-b border-l border-brand-accent"></div>
          <div class="absolute bottom-2 right-2 w-2 h-2 border-b border-r border-brand-accent"></div>
        </div>

        <!-- Zoom Hint -->
        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
          <div class="bg-brand-bg/80 backdrop-blur-sm p-3 rounded-full border border-brand-accent/50 shadow-lg shadow-brand-accent/20 text-brand-accent">
            <Maximize2 size={24} />
          </div>
        </div>
      </div>

      <!-- Lightbox Modal -->
      <dialog id={`dialog-${slug}`} class="project-dialog bg-transparent backdrop:bg-black/90 p-4 max-w-6xl w-full max-h-screen outline-none border-none overflow-hidden">
        <div class="relative w-full h-full flex flex-col items-center justify-center gap-4">
          <button 
            class="close-dialog absolute top-0 right-0 md:-top-2 md:-right-2 text-white/50 hover:text-brand-accent transition-colors p-2 z-50"
            data-slug={slug}
          >
            <X size={32} />
          </button>

          <div class="relative w-full max-h-[85vh] flex items-center justify-center">
             {isVideo ? (
              <video src={mediaSource} controls loop class="max-w-full max-h-[80vh] rounded-lg border border-brand-border shadow-2xl" />
            ) : (
              <img 
                src={image} 
                alt={title} 
                class="max-w-full max-h-[80vh] rounded-lg border border-brand-border shadow-2xl object-contain" 
              />
            )}
          </div>

          <div class="text-center max-w-2xl px-4">
            <h3 class="text-xl font-bold text-white mb-1">{title}</h3>
            <p class="text-brand-muted text-sm">{description[lang]}</p>
          </div>
        </div>
      </dialog>
    </>
  )}

  <div class="flex items-baseline justify-between gap-3 mb-3">
    <h3 class="text-base font-semibold tracking-tight text-brand-text">{title}</h3>
    <span class="text-xs font-mono text-brand-muted">{year}</span>
  </div>

  <p class="text-sm leading-relaxed text-brand-muted mb-4 flex-1">{displayDesc}</p>

  <footer class="mt-auto flex items-center justify-between gap-4 flex-wrap">
    <ul class="flex flex-wrap gap-2" aria-label="Teknologi">
      {tags.map((tag) => (
        <li class="text-[10px] font-mono text-brand-accent px-2 py-0.5 bg-brand-accent-dim border border-brand-accent-dim rounded">
          {tag}
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-4">
      {href && (
        <a href={href} class="text-brand-accent hover:opacity-70 transition-opacity" target="_blank" rel="noopener noreferrer" title="Live Preview">
          <ExternalLink size={16} />
        </a>
      )}
      {frontend_repo && (
        <a href={frontend_repo} class="text-brand-accent hover:opacity-70 transition-opacity" target="_blank" rel="noopener noreferrer" title="Frontend Repo">
          <Layout size={16} />
        </a>
      )}
      {backend_repo && (
        <a href={backend_repo} class="text-brand-accent hover:opacity-70 transition-opacity" target="_blank" rel="noopener noreferrer" title="Backend Repo">
          <Database size={16} />
        </a>
      )}
      {repo && !frontend_repo && !backend_repo && (
        <a href={repo} class="text-brand-accent hover:opacity-70 transition-opacity" target="_blank" rel="noopener noreferrer" title="Source Code">
          <Code size={16} />
        </a>
      )}
      {downloads && downloads.map((dl) => {
        const Icon = getPlatformIcon(dl.platform);
        return (
          <a href={dl.url} class="text-brand-accent hover:opacity-70 transition-opacity" target="_blank" rel="noopener noreferrer" title={`Download for ${dl.platform}`}>
            <Icon size={16} />
          </a>
        );
      })}
      {download_url && !downloads && (
        <a href={download_url} class="text-brand-accent hover:opacity-70 transition-opacity" target="_blank" rel="noopener noreferrer" title="Download">
          <Download size={16} />
        </a>
      )}
    </div>
  </footer>
</article>

<script>
  function setupDialogs() {
    const containers = document.querySelectorAll('.project-media-container');
    const closeButtons = document.querySelectorAll('.close-dialog');
    const dialogs = document.querySelectorAll('.project-dialog');

    containers.forEach(container => {
      const video = container.querySelector('.video-preview') as HTMLVideoElement;
      const card = container.closest('article');

      if (video && card) {
        // Play when hovering the entire card (keep muted for preview)
        card.addEventListener('mouseenter', () => {
          video.play().catch(() => {});
        });

        // Pause when leaving the card
        card.addEventListener('mouseleave', () => {
          video.pause();
          video.currentTime = 0;
        });
      }

      container.addEventListener('click', (e) => {
        const slug = container.getAttribute('data-slug');
        const dialog = document.getElementById(`dialog-${slug}`) as HTMLDialogElement;
        if (dialog) {
          dialog.showModal();
          document.body.style.overflow = 'hidden';
          
          // Ensure the dialog video plays
          const dialogVideo = dialog.querySelector('video');
          if (dialogVideo) {
            dialogVideo.play().catch(() => {});
          }
        }
      });
    });

    closeButtons.forEach(button => {
      button.addEventListener('click', () => {
        const slug = button.getAttribute('data-slug');
        const dialog = document.getElementById(`dialog-${slug}`) as HTMLDialogElement;
        if (dialog) {
          dialog.close();
        }
      });
    });

    dialogs.forEach(dialog => {
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) {
          (dialog as HTMLDialogElement).close();
        }
      });

      dialog.addEventListener('close', () => {
        document.body.style.overflow = '';
        // Pause dialog video when closed
        const dialogVideo = dialog.querySelector('video');
        if (dialogVideo) {
          dialogVideo.pause();
        }
      });
    });
  }

  // Run on initial load
  setupDialogs();

  // Run on view transitions if enabled
  document.addEventListener('astro:after-swap', setupDialogs);
</script>
