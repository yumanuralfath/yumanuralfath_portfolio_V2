---
// src/pages/index.astro
import Page from "../layouts/Page.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featuredProjects } from "../data/projects";
import { profile } from "../data/profile";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@/i18n/utils";
import { 
  Github, 
  Linkedin, 
  Mail, 
  Instagram, 
  Facebook, 
  MessageCircle, // for WhatsApp
  Hash, // for Discord
  Code, // for Codeberg
  Notebook // for Journal
} from "lucide-astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const socialHub = [
  { icon: MessageCircle, href: profile.links.whatsapp, label: "WhatsApp" },
  { icon: Instagram, href: profile.links.instagram, label: "Instagram" },
  { icon: Facebook, href: profile.links.facebook, label: "Facebook" },
  { icon: Hash, href: profile.links.discord, label: "Discord" },
  { icon: Linkedin, href: profile.links.linkedin, label: "LinkedIn" },
  { icon: Github, href: profile.links.github, label: "GitHub" },
  { icon: Code, href: profile.links.codeberg, label: "Codeberg" },
  { icon: Mail, href: `mailto:${profile.email}`, label: "Email" },
];
---

<Page
  title={`${profile.name} — ${profile.title}`}
  description={profile.tagline[lang]}
>
  <!-- Hero Section (Minimalist & Centered) -->
  <section class="relative pt-32 pb-24 overflow-hidden">
    <!-- Ambient Background Elements -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-4xl aspect-square bg-brand-accent/5 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute top-0 left-0 w-full h-full blueprint-grid opacity-[0.03] pointer-events-none mask-[radial-gradient(circle_at_center,black,transparent_80%)]"></div>

    <div class="container mx-auto px-6 relative z-10 flex flex-col items-center text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-accent/20 bg-brand-accent/5 text-[10px] font-mono text-brand-accent mb-6 uppercase tracking-widest">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-accent"></span>
        </span>
        {t('hero.greeting')}
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-semibold tracking-tighter leading-[0.95] mb-8 max-w-[12ch]">
        {profile.name.split(' ').map((word, i) => (
          <span class={i === profile.name.split(' ').length - 1 ? "text-brand-accent" : "text-brand-text"}>
            {word}{i !== profile.name.split(' ').length - 1 && <br class="hidden md:block" />}
            {i !== profile.name.split(' ').length - 1 && <span class="md:hidden"> </span>}
          </span>
        ))}
      </h1>

      <p class="text-lg md:text-xl text-brand-muted max-w-[32ch] leading-relaxed mb-12 mx-auto">
        {profile.tagline[lang]}
      </p>

      <div class="flex flex-wrap items-center justify-center gap-5">
        <a href="https://notes.yumana.my.id/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-10 py-4 rounded-full text-sm font-semibold bg-brand-accent text-brand-bg hover:shadow-[0_0_40px_rgba(0,255,204,0.4)] transition-all hover:scale-[1.03] group/journal active:scale-95">
          <Notebook size={18} class="mr-2.5 transition-transform group-hover/journal:rotate-12" />
          {t('hero.cta.journal')}
        </a>
        
        <div class="relative group/hub" id="social-hub">
          <button 
            id="hub-toggle"
            class="inline-flex items-center px-10 py-4 rounded-full text-sm font-semibold border border-brand-border text-brand-text hover:bg-brand-surface hover:border-brand-accent/30 transition-all cursor-pointer active:scale-95"
          >
            {t('hero.cta.contact')}
          </button>
          
          <div 
            id="hub-panel"
            class="absolute bottom-full left-1/2 -translate-x-1/2 mb-6 flex flex-wrap justify-center gap-2.5 p-4 border border-brand-border rounded-3xl glass shadow-[0_20px_50px_rgba(0,0,0,0.5)] opacity-0 translate-y-6 pointer-events-none group-hover/hub:md:opacity-100 group-hover/hub:md:translate-y-0 group-hover/hub:md:pointer-events-auto transition-all duration-500 w-72 z-20 before:absolute before:w-full before:h-6 before:top-full before:left-0 before:content-['']"
          >
            <div class="absolute inset-0 blueprint-grid opacity-10 pointer-events-none rounded-3xl"></div>
            {socialHub.map(({ icon: SocialIcon, href, label }) => (
              <a 
                href={href} 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex-1 flex items-center justify-center min-w-13.5 h-14 rounded-2xl border border-brand-border hover:border-brand-accent hover:bg-brand-accent-dim text-brand-muted hover:text-brand-accent transition-all group/icon"
                title={label}
              >
                <SocialIcon size={22} class="group-hover:scale-110 transition-transform" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const hubToggle = document.getElementById('hub-toggle');
    const hubPanel = document.getElementById('hub-panel');
    const socialHubContainer = document.getElementById('social-hub');

    hubToggle?.addEventListener('click', (e) => {
      if (window.innerWidth < 768) {
        e.stopPropagation();
        const isOpen = hubPanel?.classList.contains('opacity-100');
        if (isOpen) {
          hubPanel?.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
          hubPanel?.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        } else {
          hubPanel?.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
          hubPanel?.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        }
      }
    });

    document.addEventListener('click', (e) => {
      if (!socialHubContainer?.contains(e.target as Node)) {
        hubPanel?.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        hubPanel?.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      }
    });
  </script>

  <!-- Projects Preview -->
  <section class="py-16 border-t border-brand-border container mx-auto px-6" id="projects" aria-labelledby="h-projects">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-[10px] font-medium text-brand-muted uppercase tracking-widest" id="h-projects">{t('section.projects')}</h2>
      <a href={translatePath('/projects')} class="text-sm text-brand-accent hover:opacity-75 transition-opacity">{t('section.projects.all')}</a>
    </div>

    <div class="grid gap-4 grid-cols-[repeat(auto-fill,minmax(min(100%,300px),1fr))]">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} compact loading="lazy" />
      ))}
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-16 border-t border-brand-border container mx-auto px-6" id="about" aria-labelledby="h-about">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-[10px] font-medium text-brand-muted uppercase tracking-widest" id="h-about">{t('section.about')}</h2>
      <a href={translatePath('/about')} class="text-sm text-brand-accent hover:opacity-75 transition-opacity">{t('section.about.more')}</a>
    </div>

    <div class="flex flex-col gap-6">
      <p class="text-brand-muted max-w-[56ch] leading-[1.75]">{profile.bio_short[lang]}</p>
    </div>
  </section>
</Page>
