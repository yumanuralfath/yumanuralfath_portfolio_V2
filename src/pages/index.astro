---
// src/pages/index.astro
import Page from "../layouts/Page.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featuredProjects } from "../data/projects";
import { profile } from "../data/profile";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@/i18n/utils";
import { Image } from "astro:assets";
import { 
  Github, 
  Linkedin, 
  Mail, 
  Instagram, 
  Facebook, 
  MessageCircle, // for WhatsApp
  Hash, // for Discord
  Code, // for Codeberg
  ArrowRight,
  Notebook // for Journal
} from "lucide-astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const socialHub = [
  { icon: MessageCircle, href: profile.links.whatsapp, label: "WhatsApp" },
  { icon: Instagram, href: profile.links.instagram, label: "Instagram" },
  { icon: Facebook, href: profile.links.facebook, label: "Facebook" },
  { icon: Hash, href: profile.links.discord, label: "Discord" },
  { icon: Linkedin, href: profile.links.linkedin, label: "LinkedIn" },
  { icon: Github, href: profile.links.github, label: "GitHub" },
  { icon: Code, href: profile.links.codeberg, label: "Codeberg" },
  { icon: Mail, href: `mailto:${profile.email}`, label: "Email" },
];
---

<Page
  title={`${profile.name} — ${profile.title}`}
  description={profile.tagline[lang]}
>
  <!-- Hero Section -->
  <section class="pt-24 pb-16 container mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
    <div class="flex-1">
      <p class="text-sm font-mono text-brand-muted mb-3">{t('hero.greeting')}</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tighter leading-[1.05] mb-5">{profile.name}</h1>
      <p class="text-lg text-brand-muted max-w-[44ch] leading-relaxed mb-8">{profile.tagline[lang]}</p>

      <div class="flex flex-wrap items-center gap-3">
        <a href="#projects" class="inline-flex items-center px-6 py-3 rounded-lg text-sm font-medium bg-brand-accent text-brand-bg hover:opacity-90 transition-all hover:scale-[1.02]">
          {t('hero.cta.projects')}
          <ArrowRight size={16} class="ml-2" />
        </a>

        <a href="https://notes.yumana.my.id/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-5 py-3 rounded-lg text-sm font-medium border border-brand-border text-brand-text hover:bg-brand-surface transition-colors group/journal">
          <Notebook size={16} class="mr-2 text-brand-accent" />
          {t('hero.cta.journal')}
        </a>
        
        <!-- Social Hub -->
        <div class="relative group/hub" id="social-hub">
          <button 
            id="hub-toggle"
            class="inline-flex items-center px-6 py-3 rounded-lg text-sm font-medium border border-brand-border text-brand-text hover:bg-brand-surface transition-colors cursor-pointer active:scale-95"
          >
            {t('hero.cta.contact')}
          </button>
          
          <!-- Hover Bridge (PC) -->
          <div class="absolute bottom-full left-0 w-full h-4 bg-transparent pointer-events-auto hidden md:block"></div>

          <div 
            id="hub-panel"
            class="absolute bottom-full left-0 mb-3 flex flex-wrap gap-2 p-3 border border-brand-border rounded-xl glass shadow-2xl opacity-0 translate-y-2 pointer-events-none group-hover/hub:md:opacity-100 group-hover/hub:md:translate-y-0 group-hover/hub:md:pointer-events-auto transition-all duration-300 w-64 z-20"
          >
            <div class="absolute inset-0 blueprint-grid opacity-5 pointer-events-none rounded-xl"></div>
            {socialHub.map(({ icon: SocialIcon, href, label }) => (
              <a 
                href={href} 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex-1 flex items-center justify-center min-w-[40px] h-10 rounded-lg border border-brand-border hover:border-brand-accent hover:bg-brand-accent-dim text-brand-muted hover:text-brand-accent transition-all group/icon"
                title={label}
              >
                <SocialIcon size={18} class="group-hover/icon:scale-110 transition-transform" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Floating Atomic Avatar -->
    <div 
      id="hero-avatar"
      class="relative w-40 h-48 md:w-64 md:h-64 shrink-0 group mx-auto md:mx-0 cursor-pointer touch-manipulation"
    >
      <!-- Electron Orbits -->
      <div class="absolute inset-0 border border-brand-accent/30 rounded-full animate-[spin_20s_linear_infinite] scale-75 md:scale-100">
        <div class="absolute -top-1 left-1/2 w-2 h-2 bg-brand-accent rounded-full shadow-[0_0_15px_var(--brand-accent)]"></div>
      </div>
      <div class="absolute inset-4 border border-brand-accent/15 rounded-full animate-[spin_15s_linear_infinite_reverse] scale-75 md:scale-100">
        <div class="absolute top-1/2 -right-1 w-2 h-2 bg-brand-accent rounded-full opacity-60 shadow-[0_0_10px_var(--brand-accent)]"></div>
      </div>
      
      <div class="relative w-36 h-36 md:w-full md:h-full mx-auto rounded-full overflow-hidden border-2 border-brand-border glass p-1 md:p-1.5 transition-all duration-500 group-hover:border-brand-accent/50 group-hover:shadow-[0_0_30px_rgba(0,255,204,0.15)] dark:group-hover:shadow-[0_0_30px_rgba(0,255,204,0.1)]">
        <Image 
          id="avatar-img"
          src={profile.avatar} 
          alt={profile.name} 
          width={400} 
          height={400} 
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover rounded-full grayscale group-hover:grayscale-0 transition-all duration-700 brightness-90 group-hover:brightness-100" 
        />
        <div class="absolute inset-0 bg-brand-accent/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
      </div>
    </div>
  </section>

  <script>
    const hubToggle = document.getElementById('hub-toggle');
    const hubPanel = document.getElementById('hub-panel');
    const socialHubContainer = document.getElementById('social-hub');
    const heroAvatar = document.getElementById('hero-avatar');
    const avatarImg = document.getElementById('avatar-img');

    // Avatar interaction for mobile
    heroAvatar?.addEventListener('click', () => {
      if (window.innerWidth < 768) {
        avatarImg?.classList.toggle('grayscale');
        avatarImg?.classList.toggle('grayscale-0');
        avatarImg?.classList.toggle('brightness-90');
        avatarImg?.classList.toggle('brightness-100');
      }
    });

    hubToggle?.addEventListener('click', (e) => {
      if (window.innerWidth < 768) {
        e.stopPropagation();
        const isOpen = hubPanel?.classList.contains('opacity-100');
        if (isOpen) {
          hubPanel?.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
          hubPanel?.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        } else {
          hubPanel?.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
          hubPanel?.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
        }
      }
    });

    document.addEventListener('click', (e) => {
      if (!socialHubContainer?.contains(e.target as Node)) {
        hubPanel?.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
        hubPanel?.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      }
    });
  </script>

  <!-- Projects Preview -->
  <section class="py-16 border-t border-brand-border container mx-auto px-6" id="projects" aria-labelledby="h-projects">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-[10px] font-medium text-brand-muted uppercase tracking-widest" id="h-projects">{t('section.projects')}</h2>
      <a href={translatePath('/projects')} class="text-sm text-brand-accent hover:opacity-75 transition-opacity">{t('section.projects.all')}</a>
    </div>

    <div class="grid gap-4 grid-cols-[repeat(auto-fill,minmax(min(100%,300px),1fr))]">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} compact loading="lazy" />
      ))}
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-16 border-t border-brand-border container mx-auto px-6" id="about" aria-labelledby="h-about">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-[10px] font-medium text-brand-muted uppercase tracking-widest" id="h-about">{t('section.about')}</h2>
      <a href={translatePath('/about')} class="text-sm text-brand-accent hover:opacity-75 transition-opacity">{t('section.about.more')}</a>
    </div>

    <div class="flex flex-col gap-6">
      <p class="text-brand-muted max-w-[56ch] leading-[1.75]">{profile.bio_short[lang]}</p>
    </div>
  </section>
</Page>
