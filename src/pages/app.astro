---
// src/pages/app.astro
import Page from "@/layouts/Page.astro";
import { LogIn, UserPlus, Chrome } from "lucide-astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Page
  title={`App Login — yumana.`}
  description="Login atau daftar ke yumana. App."
>
  <div class="container mx-auto px-6 min-h-[calc(100vh-14rem)] flex items-center justify-center py-12">
    <div class="w-full max-w-md p-8 border border-brand-border rounded-xl glass relative overflow-hidden group">
      <!-- Decorative Chemistry Grid -->
      <div class="absolute inset-0 blueprint-grid opacity-5 pointer-events-none"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-brand-accent to-transparent"></div>

      <div class="relative z-10 text-center mb-10">
        <h1 class="text-3xl font-semibold tracking-tight mb-2">{t('app.title')}</h1>
        <p class="text-brand-muted text-sm">{t('app.subtitle')}</p>
      </div>

      <div class="space-y-4 relative z-10">
        <!-- Social Login -->
        <button class="w-full flex items-center justify-center gap-3 px-4 py-3 border border-brand-border rounded-lg bg-brand-surface hover:border-brand-accent transition-all group/btn cursor-pointer">
          <Chrome size={20} class="text-brand-accent group-hover/btn:scale-110 transition-transform" />
          <span class="text-sm font-medium">{t('app.google')}</span>
        </button>

        <div class="relative py-4">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-brand-border"></div>
          </div>
          <div class="relative flex justify-center text-xs uppercase">
            <span class="bg-brand-bg px-2 text-brand-muted">{t('app.or')}</span>
          </div>
        </div>

        <!-- Forms placeholder -->
        <div class="space-y-4">
          <button class="w-full flex items-center justify-center gap-3 px-4 py-3 bg-brand-accent text-brand-bg rounded-lg hover:opacity-90 transition-all font-medium text-sm cursor-pointer">
            <LogIn size={18} />
            <span>{t('app.login')}</span>
          </button>
          
          <button class="w-full flex items-center justify-center gap-3 px-4 py-3 border border-brand-border rounded-lg hover:bg-brand-surface transition-all text-sm font-medium cursor-pointer">
            <UserPlus size={18} />
            <span>{t('app.register')}</span>
          </button>
        </div>
      </div>

      <p class="mt-8 text-center text-xs text-brand-muted relative z-10">
        {t('app.terms')}
      </p>
    </div>
  </div>
</Page>
