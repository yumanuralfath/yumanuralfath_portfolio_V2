---
// src/pages/about.astro
import Page from "@/layouts/Page.astro";
import { profile } from "@/data/profile";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@/i18n/utils";
import { Image } from "astro:assets";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Page
  title={t('section.about')}
  description={profile.tagline[lang]}
>
  <div class="container mx-auto px-6 pt-12 pb-24">
    <a href={translatePath('/')} class="inline-block text-sm text-brand-muted mb-8 hover:text-brand-text transition-colors">
      {t('about.back')}
    </a>

    <div class="grid gap-12 lg:gap-20">
      <!-- Bio + Photo Section -->
      <section aria-labelledby="h-bio" class="grid lg:grid-cols-[1fr_300px] gap-12 items-start">
        <div>
          <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-2">{profile.name}</h1>
          <p class="text-sm font-mono text-brand-muted mb-8">{profile.title} · {profile.location}</p>

          <div class="flex flex-col gap-5 text-brand-muted leading-relaxed mb-10 text-base md:text-lg">
            {profile.bio_full[lang].map((para) => <p>{para}</p>)}
          </div>
        </div>

        <!-- Seamless Specimen -->
        <div 
          id="specimen-frame"
          class="relative group mx-auto lg:mx-0 order-first lg:order-last cursor-pointer touch-manipulation"
        >
          <!-- Background Atmospheric Glow -->
          <div class="absolute inset-0 bg-brand-accent/5 blur-[80px] rounded-full scale-125 group-hover:bg-brand-accent/15 transition-all duration-1000"></div>
          
          <div class="relative w-72 h-96 md:w-80 md:h-[32rem] overflow-hidden [mask-image:linear-gradient(to_bottom,black_80%,transparent_100%)]">
            <Image 
              id="specimen-img"
              src={profile.avatar} 
              alt={profile.name} 
              width={800}
              height={1000}
              loading="eager"
              fetchpriority="high"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 scale-105 group-hover:scale-100 brightness-90 group-hover:brightness-105 origin-bottom"
            />
            
            <!-- Technical Aura (Subtle) -->
            <div class="absolute inset-0 blueprint-grid opacity-10 pointer-events-none [mask-image:radial-gradient(circle,black,transparent_60%)]"></div>
            
            <!-- Soft Bottom Blend -->
            <div class="absolute inset-0 bg-linear-to-t from-brand-bg via-transparent to-transparent opacity-50"></div>
          </div>
          
          <!-- Decorative Floating Indicators -->
          <div class="absolute -right-6 top-1/3 flex flex-col gap-4 opacity-20 group-hover:opacity-100 transition-all duration-700">
            <div class="w-px h-12 bg-brand-accent"></div>
            <div class="w-px h-4 bg-brand-accent/40"></div>
          </div>

          <div class="absolute -left-6 bottom-1/3 flex flex-col gap-4 opacity-20 group-hover:opacity-100 transition-all duration-700">
            <div class="w-px h-4 bg-brand-accent/40"></div>
            <div class="w-px h-12 bg-brand-accent"></div>
          </div>

          <!-- Minimal Identity Info -->
          <div class="absolute bottom-12 -right-8 font-mono text-[9px] text-brand-muted/40 vertical-rl tracking-widest uppercase group-hover:text-brand-accent/60 transition-colors">
            {profile.location.split(',')[0]} // CHEM_COMP_LAB
          </div>
        </div>
      </section>
    </div>
  </div>

  <script>
    const specimenFrame = document.getElementById('specimen-frame');
    const specimenImg = document.getElementById('specimen-img');
    const scanLine = document.getElementById('scan-line');

    specimenFrame?.addEventListener('click', () => {
      if (window.innerWidth < 1024) { // lg breakpoint
        specimenImg?.classList.toggle('grayscale');
        specimenImg?.classList.toggle('grayscale-0');
        specimenImg?.classList.toggle('scale-105');
        specimenImg?.classList.toggle('scale-100');
        
        // Manual toggle for scan line animation on mobile
        if (specimenImg?.classList.contains('grayscale-0')) {
          scanLine?.classList.add('animate-scan');
        } else {
          scanLine?.classList.remove('animate-scan');
        }
      }
    });
  </script>
</Page>
