---
// src/layouts/Page.astro
// Layout siap pakai untuk halaman standar (beranda, about, dll)

import Base from "./Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  noindex?: boolean;
}
---

<Base {...Astro.props}>
  <Header />

  <main id="main">
    <slot />
  </main>

  <Footer />
</Base>
